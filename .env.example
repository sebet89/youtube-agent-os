APP_NAME=youtube-agent-os
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/youtube_agent_os
REDIS_URL=redis://redis:6379/0
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/oauth/youtube/callback
YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.upload,https://www.googleapis.com/auth/youtube.readonly
YOUTUBE_DEFAULT_PRIVACY_STATUS=private
MEDIA_OUTPUT_ROOT=/tmp/youtube-agent-os/assets
RENDER_OUTPUT_ROOT=/tmp/youtube-agent-os/renders
FFMPEG_BINARY=ffmpeg
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
THUMBNAIL_PROVIDER=deterministic
VIDEO_PROVIDER=ffmpeg
VERTEX_IMAGEN_MODEL=imagen-4.0-fast-generate-001
VERTEX_VEO_MODEL=veo-3.0-fast-generate-001
VERTEX_VEO_ASPECT_RATIO=16:9
VERTEX_VEO_RESOLUTION=720p
VERTEX_VEO_DURATION_SECONDS=8
VERTEX_VEO_GENERATE_AUDIO=true
TTS_PROVIDER=auto
TTS_VOICE_NAME=
TTS_RATE=0
GOOGLE_TTS_VOICE_NAME=pt-BR-Chirp3-HD-Achernar
GOOGLE_TTS_LANGUAGE_CODE=pt-BR
GOOGLE_TTS_SPEAKING_RATE=1.0
SECRET_KEY=change-me
